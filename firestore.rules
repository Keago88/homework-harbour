rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Parent-child pairing codes (studentEmail, code, parentEmails)
    match /parent_links/{docId} {
      allow read, write: if request.auth != null;
    }
    // User settings (subjects, etc.) - users can only read/write their own doc (userId = auth.uid)
    match /user_settings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // User data (assignments, profile, completion history, risk history)
    match /user_data/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Platform data (schools, alerts, interventions) - admins only for write; all auth users can read
    match /platform/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Chats (direct / group) — participants must match signed-in user's email
    match /chats/{chatId} {
      allow read: if request.auth != null && request.auth.token.email != null
        && (request.auth.token.email in resource.data.participants
            || (resource.data.viewerEmails != null && request.auth.token.email in resource.data.viewerEmails));
      allow create: if request.auth != null && request.auth.token.email != null
        && request.auth.token.email in request.resource.data.participants;
      allow update, delete: if request.auth != null && request.auth.token.email != null
        && request.auth.token.email in resource.data.participants;
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if request.auth != null && request.auth.token.email != null
        && (request.auth.token.email in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
            || (get(/databases/$(database)/documents/chats/$(chatId)).data.viewerEmails != null
                && request.auth.token.email in get(/databases/$(database)/documents/chats/$(chatId)).data.viewerEmails));
      allow create: if request.auth != null && request.auth.token.email != null
        && request.auth.token.email in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
        && request.resource.data.senderEmail == request.auth.token.email;
      allow update, delete: if false;
    }
  }
}
